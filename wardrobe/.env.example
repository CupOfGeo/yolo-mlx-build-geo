# Copy to `.env` (gitignored) and fill in real values.
# Phase 1 needs the RTSP_* vars. Phase 2 adds ANTHROPIC_API_KEY.

# Camera RTSP — preferred form. Paste your raw password; the script URL-encodes
# username and password automatically using urllib.parse.quote.
RTSP_USER=admin
RTSP_PASS=YOUR_PASSWORD_HERE
RTSP_HOST=192.168.1.108

# Optional overrides (defaults shown; uncomment to change).
# Amcrest/Dahua main stream is the default; use subtype=1 for the low-res sub-stream.
# RTSP_PORT=554
# RTSP_PATH=/cam/realmonitor?channel=1&subtype=0

# Alternative: a fully-formed URL (skips the assembly above). Must be pre-encoded
# if it contains special characters. Use this only if you have a non-standard path.
# RTSP_URL=

# Used in Phase 2 (wardrobe/analyze.py)
ANTHROPIC_API_KEY=
